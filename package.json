{
  "name": "kbsl_screen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:types": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate-model": "protoc --plugin=protoc-gen-ts_proto=.\\node_modules\\.bin\\protoc-gen-ts_proto.cmd --ts_proto_opt=esModuleInterop=true --ts_proto_opt=useOptionals=all --ts_proto_out=src/services/protos --proto_path=protobuf ./protobuf/discord.proto ./protobuf/models.proto ./protobuf/packets.proto"
  },
  "dependencies": {
    "jotai": "^2.18.1",
    "lodash-es": "^4.17.23",
    "long": "^5.3.2",
    "protobufjs": "^8.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-error-boundary": "^6.1.1",
    "react-icons": "^5.6.0",
    "react-query": "^3.39.3",
    "react-use": "^17.6.0",
    "react-use-websocket": "^4.13.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-proto": "^2.11.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-cloudflare-functions": "^0.8.4"
  },
  "prettier": {
    "trailingComma": "all",
    "printWidth": 100
  }
